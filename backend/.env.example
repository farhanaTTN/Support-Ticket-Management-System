# SQLite database file location (relative to the prisma/ schema directory)
DATABASE_URL="file:./dev.db"

# API server port
PORT=4000

# Comma-separated list of allowed CORS origins (frontend dev server)
CORS_ORIGIN="http://localhost:5173"

# Secret used to sign JWT access tokens. Change this to a long random string.
# Never commit a real secret; this example value is for local development only.
JWT_SECRET="dev-only-insecure-secret-change-me"

# Access token lifetime (see the "ms"/jsonwebtoken duration format)
JWT_EXPIRES_IN="8h"

# Password assigned to every seeded demo user (local/dev convenience only).
SEED_PASSWORD="Password123!"
